class Solution {
    public char findTheDifference(String s, String t) {
        char[] arr1=s.toCharArray();
        char[] arr2=t.toCharArray();
        Arrays.sort(arr1);
        Arrays.sort(arr2);
        int i=0;
        int j=0;
        while(i<arr1.length && j<arr2.length){
            if(arr1[i]!=arr2[j]){
                return arr2[j];
            }
            i++;
            j++;
        }
        return arr2[arr2.length-1];
    }
}